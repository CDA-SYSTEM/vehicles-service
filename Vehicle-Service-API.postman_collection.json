            }
          ]
        },
        {
          "name": "Listar vehículos por cliente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehiculo/cliente/CLI-001?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo", "cliente", "CLI-001"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Lista vehículos de un cliente específico con paginación."
          }
        },
        {
          "name": "Actualizar vehículo",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"CLI-001\",\n  \"marcaId\": 1,\n  \"claseId\": 1,\n  \"lineaId\": 1,\n  \"colorId\": 2,\n  \"tipoVehiculoId\": 1,\n  \"tipoCombustibleId\": 1,\n  \"tipoServicioId\": 1,\n  \"modelo\": \"2024\",\n  \"placa\": \"ABC-123\",\n  \"certificadoNo\": \"CERT-001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vehiculo/{{vehiculoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo", "{{vehiculoId}}"]
            },
            "description": "Actualiza los datos de un vehículo existente."
          }
        },
        {
          "name": "Eliminar vehículo",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehiculo/{{vehiculoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo", "{{vehiculoId}}"]
            },
            "description": "Elimina un vehículo por su ID. Retorna 204 No Content."
          },
          "response": [
