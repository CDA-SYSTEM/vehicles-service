{
  "info": {
    "name": "Vehicle Service API",
    "description": "Colección de endpoints para el microservicio de vehículos (CDA System).\n\n## Autenticación\nTodas las rutas (excepto health) requieren el header `x-api-key`.\n\n## Variables de colección\n- `baseUrl`: URL base del servicio\n- `apiKey`: API Key definida en .env\n- `vehiculoId`: ID de vehículo para consultas/actualizaciones\n- `catalogType`: Tipo de catálogo para endpoints unificados\n- `catalogItemId`: ID de ítem en catálogo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "URL base del servicio. Sin barra final."
    },
    {
      "key": "apiKey",
      "value": "cda-vehicle-service-secret-key-2026",
      "type": "string",
      "description": "API Key para autenticación."
    },
    {
      "key": "vehiculoId",
      "value": "1",
      "type": "string",
      "description": "ID del vehículo a consultar/modificar."
    },
    {
      "key": "catalogType",
      "value": "marcas",
      "type": "string",
      "description": "Tipo de catálogo: marcas, clases, lineas, colores, tipos-vehiculo, tipos-combustible, tipos-servicio"
    },
    {
      "key": "catalogItemId",
      "value": "1",
      "type": "string",
      "description": "ID del ítem en el catálogo."
    }
  ],
  "header": [
    {
      "key": "Content-Type",
      "value": "application/json",
      "type": "default"
    },
    {
      "key": "Accept",
      "value": "application/json",
      "type": "default"
    },
    {
      "key": "x-api-key",
      "value": "{{apiKey}}",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Endpoints de monitoreo",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Verifica que el servicio esté activo. No requiere API Key."
          },
          "response": [
            {
              "name": "UP",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"status\": \"UP\",\n  \"timestamp\": \"2026-05-18T22:00:00.000\",\n  \"service\": \"vehicles-service\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Vehiculos",
      "description": "CRUD completo de vehículos",
      "item": [
        {
          "name": "Crear vehículo",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"CLI-001\",\n  \"marcaId\": 1,\n  \"claseId\": 1,\n  \"lineaId\": 1,\n  \"colorId\": 1,\n  \"tipoVehiculoId\": 1,\n  \"tipoCombustibleId\": 1,\n  \"tipoServicioId\": 1,\n  \"modelo\": \"2023\",\n  \"placa\": \"ABC-123\",\n  \"certificadoNo\": \"CERT-001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vehiculo",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo"]
            },
            "description": "Crea un nuevo vehículo. Retorna 201 Created con Location header."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Location", "value": "http://localhost:8080/vehiculo/1" }
              ],
              "body": "{\n  \"id\": 1,\n  \"clienteId\": \"CLI-001\",\n  \"marca\": { \"id\": 1, \"nombre\": \"Toyota\" },\n  \"clase\": { \"id\": 1, \"nombre\": \"Sedan\" },\n  \"linea\": { \"id\": 1, \"nombre\": \"Corolla\" },\n  \"color\": { \"id\": 1, \"nombre\": \"Blanco\" },\n  \"tipoVehiculo\": { \"id\": 1, \"nombre\": \"Particular\" },\n  \"tipoCombustible\": { \"id\": 1, \"nombre\": \"Gasolina\" },\n  \"tipoServicio\": { \"id\": 1, \"nombre\": \"Particular\" },\n  \"modelo\": \"2023\",\n  \"placa\": \"ABC-123\",\n  \"certificadoNo\": \"CERT-001\"\n}"
            }
          ]
        },
        {
          "name": "Listar vehículos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehiculo?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo"],
              "query": [
                { "key": "page", "value": "0", "description": "Número de página (0-based)" },
                { "key": "size", "value": "20", "description": "Tamaño de página" },
                { "key": "sort", "value": "id,asc", "description": "Campo y dirección de ordenamiento", "disabled": true },
                { "key": "clienteId", "value": "", "description": "Filtro opcional por ID de cliente", "disabled": true }
              ]
            },
            "description": "Lista vehículos paginados. Opcionalmente filtra por clienteId."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"content\": [],\n  \"pageable\": { \"pageNumber\": 0, \"pageSize\": 20 },\n  \"totalElements\": 0,\n  \"totalPages\": 0\n}"
            }
          ]
        },
        {
          "name": "Obtener vehículo por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehiculo/{{vehiculoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vehiculo", "{{vehiculoId}}"]
            },
            "description": "Obtiene un vehículo por su ID numérico."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"clienteId\": \"CLI-001\",\n  \"marca\": { \"id\": 1, \"nombre\": \"Toyota\" },\n  \"clase\": { \"id\": 1, \"nombre\": \"Sedan\" },\n  \"linea\": { \"id\": 1, \"nombre\": \"Corolla\" },\n  \"color\": { \"id\": 1, \"nombre\": \"Blanco\" },\n  \"tipoVehiculo\": { \"id\": 1, \"nombre\": \"Particular\" },\n  \"tipoCombustible\": { \"id\": 1, \"nombre\": \"Gasolina\" },\n  \"tipoServicio\": { \"id\": 1, \"nombre\": \"Particular\" },\n  \"modelo\": \"2023\",\n  \"placa\": \"ABC-123\",\n  \"certificadoNo\": \"CERT-001\"\n}"
