# Configuración de ejemplo para variables de entorno
# Copia este archivo como .env y ajusta los valores según tu entorno

# Base de datos
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/vehicles
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=/

# Exchange de eventos (Topic) para el tracker service
APP_RABBITMQ_EVENT_EXCHANGE=cda.domain.events
APP_RABBITMQ_ROUTING_KEY_VEHICULO=vehiculo.registro.creado

# Cola RPC y timeout
APP_RABBITMQ_VEHICLE_QUEUE=vehicle-service-queue
APP_RABBITMQ_RPC_TIMEOUT_MS=8000

# Seguridad - API Key para el header x-api-key (requerido)
API_KEY=your-api-key-here
